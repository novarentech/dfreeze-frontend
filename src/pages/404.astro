---
import MainLayout from '../layouts/MainLayout.astro';
Astro.response.status = 404;
---

<MainLayout
  title="404 – Halaman Tidak Ditemukan"
  description="Maaf, halaman yang Anda cari tidak ditemukan di DFreeze Vet Clinic."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20">
    <div class="text-center max-w-lg mx-auto">

      <!-- Illustration: Lost pet -->
      <div class="relative w-52 h-52 mx-auto mb-10">
        <div class="w-full h-full rounded-full bg-blue-50 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" class="w-44 h-44">
            <!-- Sad dog illustration -->
            <circle cx="100" cy="105" r="45" fill="#FDE68A"/>
            <!-- Head -->
            <circle cx="100" cy="90" r="32" fill="#FDE68A"/>
            <!-- Ears -->
            <ellipse cx="76" cy="70" rx="14" ry="20" fill="#F59E0B" transform="rotate(-20 76 70)"/>
            <ellipse cx="124" cy="70" rx="14" ry="20" fill="#F59E0B" transform="rotate(20 124 70)"/>
            <!-- Sad eyes -->
            <ellipse cx="89" cy="87" rx="4" ry="5" fill="#1E3A5F"/>
            <ellipse cx="111" cy="87" rx="4" ry="5" fill="#1E3A5F"/>
            <!-- Eyebrows sad -->
            <path d="M84 79 Q89 76 94 80" fill="none" stroke="#B45309" stroke-width="2" stroke-linecap="round"/>
            <path d="M106 80 Q111 76 116 79" fill="none" stroke="#B45309" stroke-width="2" stroke-linecap="round"/>
            <!-- Nose -->
            <ellipse cx="100" cy="97" rx="5" ry="3.5" fill="#B45309"/>
            <!-- Sad mouth -->
            <path d="M93 104 Q100 100 107 104" fill="none" stroke="#B45309" stroke-width="2" stroke-linecap="round"/>
            <!-- Tear drops -->
            <ellipse cx="85" cy="95" rx="2" ry="3" fill="#93C5FD" opacity="0.8"/>
            <ellipse cx="115" cy="95" rx="2" ry="3" fill="#93C5FD" opacity="0.8"/>
            <!-- Paws -->
            <ellipse cx="72" cy="148" rx="14" ry="10" fill="#FDE68A"/>
            <ellipse cx="128" cy="148" rx="14" ry="10" fill="#FDE68A"/>
            <!-- Tail down (sad) -->
            <path d="M140 130 Q160 150 145 165" fill="none" stroke="#FDE68A" stroke-width="8" stroke-linecap="round"/>
            <!-- Question mark -->
            <text x="155" y="65" font-size="30" font-weight="bold" fill="#2563eb" font-family="Arial">?</text>
          </svg>
        </div>

        <!-- 404 badge -->
        <div class="absolute -top-3 -right-3 bg-blue-600 text-white text-xl font-extrabold w-14 h-14 rounded-full flex items-center justify-center shadow-lg">
          404
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">
        Ups! Halaman Tidak Ditemukan
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mb-8">
        Anjing pelacak kami sudah berusaha keras, tapi halaman yang Anda cari sepertinya kabur entah ke mana. Mungkin sudah pindah atau memang tidak pernah ada.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/"
          id="back-home-404"
          class="inline-flex items-center gap-2 bg-blue-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-blue-700 active:scale-95 transition-all shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Kembali ke Beranda
        </a>
        <a
          href="/artikel"
          id="to-artikel-404"
          class="inline-flex items-center gap-2 border border-slate-300 text-slate-700 font-semibold px-6 py-3 rounded-xl hover:bg-slate-50 hover:border-blue-300 hover:text-blue-700 transition-all"
        >
          Baca Artikel
        </a>
      </div>
    </div>
  </section>
</MainLayout>
