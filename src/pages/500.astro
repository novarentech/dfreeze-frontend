---
import MainLayout from '@/layouts/MainLayout.astro';
Astro.response.status = 500;
---

<MainLayout
  title="500 – Gangguan Teknis"
  description="Sistem DFreeze Vet Clinic sedang mengalami gangguan teknis sementara. Tim kami sedang menanganinya."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20">
    <div class="text-center max-w-lg mx-auto">

      <!-- Illustration: Server with stethoscope -->
      <div class="relative w-52 h-52 mx-auto mb-10">
        <div class="w-full h-full rounded-full bg-red-50 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" class="w-40 h-40">
            <!-- Server box -->
            <rect x="45" y="50" width="110" height="100" rx="10" fill="#F1F5F9" stroke="#CBD5E1" stroke-width="2"/>
            <!-- Server lines -->
            <rect x="55" y="65" width="90" height="18" rx="4" fill="#E2E8F0"/>
            <circle cx="135" cy="74" r="4" fill="#22C55E"/>
            <rect x="55" y="90" width="90" height="18" rx="4" fill="#E2E8F0"/>
            <circle cx="135" cy="99" r="4" fill="#EF4444"/>
            <rect x="55" y="115" width="90" height="18" rx="4" fill="#E2E8F0"/>
            <circle cx="135" cy="124" r="4" fill="#F59E0B"/>
            <!-- Stethoscope -->
            <path d="M70 85 Q55 85 55 100 Q55 115 65 120" fill="none" stroke="#2563EB" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="65" cy="124" r="6" fill="#2563EB"/>
            <circle cx="65" cy="124" r="3" fill="#DBEAFE"/>
            <line x1="70" x2="70" y1="75" y2="85" stroke="#2563EB" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="70" cy="73" r="4" fill="#2563EB"/>
            <!-- Warning sign -->
            <text x="130" y="48" font-size="32" fill="#EF4444">⚠</text>
          </svg>
        </div>

        <!-- 500 badge -->
        <div class="absolute -top-3 -right-3 bg-red-500 text-white text-xl font-extrabold w-14 h-14 rounded-full flex items-center justify-center shadow-lg">
          500
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">
        Gangguan Teknis Sementara
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mb-3">
        Sistem klinik kami sedang mengalami gangguan teknis sementara. Tim teknisi kami sudah mengetahui masalah ini dan sedang bekerja keras untuk mengatasinya.
      </p>
      <p class="text-slate-400 text-sm mb-8">
        Mohon maaf atas ketidaknyamanan ini. Silakan coba lagi dalam beberapa menit.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/"
          id="back-home-500"
          class="inline-flex items-center gap-2 bg-blue-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-blue-700 active:scale-95 transition-all shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Kembali ke Beranda
        </a>
        <button
          id="retry-btn-500"
          onclick="window.location.reload()"
          class="inline-flex items-center gap-2 border border-slate-300 text-slate-700 font-semibold px-6 py-3 rounded-xl hover:bg-slate-50 hover:border-blue-300 hover:text-blue-700 transition-all cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/>
          </svg>
          Coba Lagi
        </button>
      </div>

      <!-- Contact info -->
      <p class="mt-10 text-sm text-slate-400">
        Butuh bantuan mendesak?
        <a href="tel:+62211234567" class="text-blue-600 font-medium hover:underline ml-1">(021) 123-4567</a>
      </p>
    </div>
  </section>
</MainLayout>
