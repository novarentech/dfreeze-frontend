---
import MainLayout from '@/layouts/MainLayout.astro';
import CTA from '@/components/section/CTA.astro';
import Hero from '@/components/section/Hero.astro';
import AboutUs from '@/components/section/AboutUs.astro';
import Facilities from '@/components/section/Facilities.astro';
import Location from '@/components/section/Location.astro';
import Services from '@/components/section/Services.astro';
import Testimonials from '@/components/section/Testimonials.astro';
import Gallery from '@/components/section/Gallery.astro';
import PopularArticles from '@/components/section/PopularArticles.astro';
import FloatingEmergencyButton from '@/components/ui/FloatingEmergencyButton';


const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "VeterinaryCare",
  "name": "DFreeze Vet Clinic",
  "image": "https://dfreeze.novarentech.com/og-image.jpg",
  "@id": "https://dfreeze.novarentech.com",
  "url": "https://dfreeze.novarentech.com",
  "telephone": "+62211234567",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jl. Kesehatan No. 1",
    "addressLocality": "Jakarta Selatan",
    "addressRegion": "DKI Jakarta",
    "postalCode": "12345",
    "addressCountry": "ID"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  }
};
---

<MainLayout
  title="Beranda"
  description="DFreeze Vet Clinic – Klinik hewan terpercaya untuk perawatan kesehatan hewan peliharaan Anda. Konsultasi, vaksinasi, grooming, dan bedah."
  jsonld={localBusinessSchema}
>
  <!-- Hero Section -->
  <div id="hero">
    <Hero />
  </div>

  <!-- Tentang Kami -->
  <AboutUs id="about"/>

  <!-- Layanan Section -->
  <Services id="services"/>
  
  <!-- Fasilitas Section -->
  <div id="fasilitas">
    <Facilities />
  </div>

  <!-- Testimonials Section -->
  <div id="testimoni">
    <Testimonials />
  </div>

  <!-- Galeri Section -->
  <div id="galeri">
    <Gallery />
  </div>

  <!-- Why Us Section -->
  <div id="cta">
    <CTA />
  </div>

    <!-- Lokasi Section -->
  <div id="lokasi">
    <Location />
  </div>


  <FloatingEmergencyButton client:load />
</MainLayout>

