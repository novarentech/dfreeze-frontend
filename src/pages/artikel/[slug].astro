---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { renderStrapiBlocks } from '../../lib/utils/strapi.js';
import { getArticleBySlug } from '../../lib/api/articles';
import { getThumbnailUrl } from "../../lib/utils/media";

const { slug } = Astro.params;

let article = null;

// ❗ validasi slug
if (!slug) {
  return Astro.redirect('/404');
}

try {
  article = await getArticleBySlug(slug);
} catch (err) {
  console.error("Fetch article error:", err);
}

if (!article) {
  return Astro.redirect('/404');
}

const thumbnailUrl = getThumbnailUrl(article.thumbnail);

const contentHtml = renderStrapiBlocks(article.content);

const publishedDate = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('id-ID', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<MainLayout
  title={article.title ?? 'Artikel'}
  description={article.title ?? 'Baca artikel kesehatan hewan peliharaan di DFreeze Vet Clinic.'}
>
  <article class="py-12 max-w-3xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-600 transition-colors">Beranda</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/artikel" class="hover:text-blue-600 transition-colors">Artikel</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-slate-600 truncate max-w-[200px]">{article.title}</span>
    </nav>

    <!-- Category badge -->
    {article.category && (
      <span class="inline-block text-xs font-medium text-blue-600 bg-blue-50 px-3 py-1.5 rounded-full mb-4 capitalize">
        {article.category}
      </span>
    )}

    <!-- Title -->
    <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight mb-4">
      {article.title}
    </h1>

    <!-- Meta info -->
    <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400 mb-8 pb-6 border-b border-slate-100">
      {publishedDate && (
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          <time>{publishedDate}</time>
        </div>
      )}
      {article.viewed != null && (
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          <span>{article.viewed.toLocaleString('id-ID')} kali dibaca</span>
        </div>
      )}
    </div>

    <!-- Thumbnail -->
    {thumbnailUrl && (
      <div class="rounded-2xl overflow-hidden mb-10 aspect-video bg-slate-100">
        <img
          src={thumbnailUrl}
          alt={article.thumbnail?.alternativeText ?? article.title}
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- Content dari Strapi blocks -->
    {contentHtml ? (
      <div
        class="prose prose-slate prose-lg max-w-none
          prose-headings:font-bold prose-headings:text-slate-900
          prose-p:text-slate-700 prose-p:leading-relaxed
          prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
          prose-img:rounded-xl prose-img:shadow-md
          prose-blockquote:border-l-4 prose-blockquote:border-blue-400 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-slate-600
          prose-code:text-blue-700 prose-code:bg-blue-50 prose-code:rounded prose-code:px-1 prose-code:py-0.5
          prose-pre:bg-slate-900 prose-pre:text-slate-100 prose-pre:rounded-xl
          prose-ul:list-disc prose-ol:list-decimal
          prose-li:text-slate-700
          prose-strong:text-slate-900 prose-strong:font-semibold"
        set:html={contentHtml}
      />
    ) : (
      <p class="text-slate-400 italic">Konten artikel tidak tersedia.</p>
    )}

    <!-- Back navigation -->
    <div class="mt-14 pt-8 border-t border-slate-100 flex items-center justify-between">
      <a
        href="/artikel"
        id="back-to-artikel"
        class="inline-flex items-center gap-2 text-blue-600 font-medium hover:gap-3 transition-all text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Kembali ke Daftar Artikel
      </a>
    </div>
  </article>
</MainLayout>
