---
export const prerender = false;

import MainLayout from '@/layouts/MainLayout.astro';
import CTA from '@/components/section/CTA.astro';
import { BlocksRenderer } from '@strapi/blocks-react-renderer';
import { getArticleBySlug } from '@/lib/api/articles';
import { getThumbnailUrl } from "@/lib/utils/media";
import { Calendar, ChevronLeft, ChevronRight, Eye } from 'lucide-react';

const { slug } = Astro.params;

let article = null;

// ❗ validasi slug
if (!slug) {
  return Astro.redirect('/404');
}

try {
  article = await getArticleBySlug(slug);
} catch (err) {
  console.error("Fetch article error:", err);
}

if (!article) {
  return Astro.redirect('/404');
}

const thumbnailUrl = getThumbnailUrl(article.thumbnail);

const publishedDate = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('id-ID', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "image": [
    thumbnailUrl ? new URL(thumbnailUrl, 'https://dfreeze.novarentech.com').href : "https://dfreeze.novarentech.com/og-image.jpg"
  ],
  "datePublished": article.publishedAt || article.createdAt,
  "dateModified": article.updatedAt || article.publishedAt || article.createdAt,
  "author": [{
      "@type": "Person",
      "name": "DFreeze Vet Team",
      "url": "https://dfreeze.novarentech.com"
  }]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Beranda",
      "item": "https://dfreeze.novarentech.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Artikel",
      "item": "https://dfreeze.novarentech.com/artikel"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": article.title,
      "item": `https://dfreeze.novarentech.com/artikel/${slug}`
    }
  ]
};
---

<MainLayout
  title={article.title ?? 'Artikel'}
  description={article.title ?? 'Baca artikel kesehatan hewan peliharaan di DFreeze Vet Clinic.'}
  image={thumbnailUrl}
  type="article"
  jsonld={[articleSchema, breadcrumbSchema]}
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mt-4 pt-8 border-t border-slate-100 flex items-center justify-between">
      <a
        href="/artikel"
        id="back-to-artikel"
        class="inline-flex items-center gap-2 text-slate-600 font-medium hover:gap-3 transition-all text-sm"
      >
        <ChevronLeft size={16}/>
        Kembali ke Daftar Artikel
      </a>
    </div>

    <article class="mt-6 lg:p-12 md:p-8 p-4 rounded-2xl border">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Beranda</a>
        <ChevronRight size={14}/>
        <a href="/artikel" class="hover:text-primary transition-colors">Artikel</a>
        <ChevronRight size={14}/>
        <span class="text-slate-600 truncate max-w-[200px]">{article.title}</span>
      </nav>

      <!-- Title -->
      <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 leading-tight mb-4">
        {article.title}
      </h1>

      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400 mb-8">
        {publishedDate && (
          <div class="flex items-center gap-1.5">
            <Calendar size={14} stroke-width={2}/>
            <time>{publishedDate}</time>
          </div>
        )}
        {article.viewed != null && (
          <div class="flex items-center gap-1.5">
            <Eye size={14} stroke-width={2}/>
            <span>{article.viewed.toLocaleString('id-ID')} kali dibaca</span>
          </div>
        )}
      </div>

      <!-- Thumbnail -->
      {thumbnailUrl && (
        <div class="rounded-3xl overflow-hidden mb-10 aspect-video bg-slate-100 shadow-xl">
          <img
            src={thumbnailUrl}
            alt={article.thumbnail?.alternativeText ?? article.title}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      )}

      <!-- Content dari Strapi blocks -->
      {article.content ? (
        <div
          class="prose prose-slate prose-lg max-w-none
            prose-headings:font-bold prose-headings:text-slate-900
            prose-p:text-slate-700 prose-p:leading-relaxed
            prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
            prose-img:rounded-xl prose-img:shadow-md
            prose-blockquote:border-l-4 prose-blockquote:border-blue-400 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-slate-600
            prose-code:text-blue-700 prose-code:bg-blue-50 prose-code:rounded prose-code:px-1 prose-code:py-0.5
            prose-pre:bg-slate-900 prose-pre:text-slate-100 prose-pre:rounded-xl
            prose-ul:list-disc prose-ol:list-decimal
            prose-li:text-slate-700
            prose-strong:text-slate-900 prose-strong:font-semibold"
        >
          <BlocksRenderer content={article.content} />
        </div>
      ) : (
        <p class="text-slate-400 italic">Konten artikel tidak tersedia.</p>
      )}
    </article>
  </div>
  <CTA />
</MainLayout>
