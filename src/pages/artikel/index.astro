---
export const prerender = false;

import MainLayout from '@/layouts/MainLayout.astro';
import PopularArticles from '@/components/section/PopularArticles.astro';
import OtherArticles from '@/components/section/OtherArticles.astro';
import NewestArticles from '@/components/NewestArticles.astro';
---

<MainLayout
  title="Artikel Kesehatan"
  description="Baca artikel dan tips kesehatan hewan peliharaan dari dokter hewan berpengalaman DFreeze Vet Clinic."
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="py-14 ">
      <div class="max-w-4xl">
        <span class="text-primary text-sm font-semibold uppercase tracking-widest">Pusat Informasi</span>
        <h1 class="mt-3 text-3xl md:text-5xl font-extrabold text-slate-900 leading-tight tracking-tight">
          Tips & Informasi Kesehatan Hewan
        </h1>
        <p class="mt-4 text-lg md:text-xl text-slate-500 leading-relaxed max-w-2xl">
          Edukasi terbaik untuk pemilik hewan kesayangan, dari tips harian hingga panduan medis darurat.
        </p>
      </div>
    </header>

    <PopularArticles />

    <NewestArticles />

    <OtherArticles />
  </div>
</MainLayout>
