---
import SEO from '@/components/SEO/SEO.astro';
import GoogleAnalytics from '@/components/SEO/GoogleAnalytics.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import { Toaster } from "@/components/ui/sonner";

import '../styles/global.css';

const { title, description, image, type, jsonld } = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <SEO title={title} description={description} image={image} type={type} jsonld={jsonld} />
    <GoogleAnalytics />
  </head>
  <body class="bg-background antialiased">

    <!-- Navbar -->
    <Navbar />

    <!-- Main Content -->
    <main class="container mx-auto">
      <div class="px-4 sm:px-6 lg:px-8 pt-24">
        <slot />
      </div>
    </main>

    <Footer />
    <Toaster richColors position="top-right" client:load/>
  </body>
</html>
