---
import { Image } from "astro:assets";
import bgHero from "@/assets/image/bgHero.jpg";
import heroSection from "@/assets/image/heroSection.png";
import { Button } from "@/components/ui/button";
import BookingModal from "@/components/BookingModal.tsx";
---

<!-- Hero Section -->
<section class="relative pt-20 md:py-32 w-screen left-1/2 -translate-x-1/2 min-h-fit md:min-h-[calc(100vh-97px)]">
    <!-- Background -->
    <div class="absolute inset-0 -z-10">
        <!-- Optimized Background Image -->
        <Image 
            src={bgHero} 
            alt="Hero Background Pattern" 
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
        />
        <!-- Decorative Overlays -->
        <div class="absolute inset-0 bg-linear-to-b from-primary/80 via-primary/60 to-primary/95"></div>
    </div>
    
    <!-- Text Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 items-center text-white gap-4">
            <div class="space-y-8 z-10 md:py-32">
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">    
                    Perawatan Terbaik untuk Hewan Peliharaan Anda
                </h1>

                <p class="text-lg md:text-xl leading-relaxed max-w-2xl text-slate-100">
                    Klinik hewan profesional dengan dokter berpengalaman, fasilitas modern, dan layanan darurat yang siap 24 jam untuk menjaga hewan kesayanganmu tetap sehat dan bahagia.
                </p>

                <div class="flex flex-wrap gap-4">
                    <BookingModal client:load variant="cta" />
                    <Button 
                        variant="outline" 
                        size="xl" 
                        className="rounded-full px-8 py-6 border-white/40 text-white hover:bg-white/10 backdrop-blur-sm transition-all bg-transparent hover:text-white/80 w-full md:w-auto"
                    >
                        Lihat Layanan Kami
                    </Button>
                </div>
            </div>

            <!-- Hero Illustration -->
            <div class="relative z-0 flex justify-end items-end self-end lg:-mb-45">
                <Image
                    src={heroSection} 
                    alt="Ilustrasi Utama Perawatan Hewan" 
                    class="w-full h-auto max-w-[400px] md:max-w-[600px] lg:max-w-[750px] object-contain object-bottom"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
        </div>
    </div>
</section>