---
import GalleryGrid from "../GalleryGrid";

import bedah from "@/assets/image/services/bedah_operasi.jpg";
import grooming from "@/assets/image/services/grooming.jpg";
import nutrisi from "@/assets/image/services/konsultasi_nutrisi.jpg";
import pemeriksaan from "@/assets/image/services/pemeriksaan_umum.jpg";
import mulut from "@/assets/image/services/perawatan_mulut.jpg";
import vaksin from "@/assets/image/services/vaksinasi.jpg";

const serviceImages = [bedah, grooming, nutrisi, pemeriksaan, mulut, vaksin];

// Generate an array of 15 images by cycling through the available service images
// Passing the full image object to provide width/height metadata to the React component
const images = Array.from({ length: 15 }, (_, i) => serviceImages[i % serviceImages.length]);
---

<section id="galeri" class="w-full bg-white overflow-hidden py-10 md:py-20 border-b border-slate-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 mb-10">
    <p class="text-primary text-sm font-bold uppercase tracking-widest mb-3">GALERI KLINIK</p>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <h2 class="text-3xl md:text-5xl font-bold text-slate-800 leading-tight max-w-2xl">
        Momen Keseharian di <span class="text-primary tracking-tight">DFreeze Clinic</span>
      </h2>
      <p class="text-slate-500 max-w-sm text-sm md:text-base leading-relaxed">
        Cuplikan dedikasi kami dalam merawat dan menjaga kesehatan seluruh hewan kesayangan Anda.
      </p>
    </div>
  </div>
  
  <GalleryGrid images={images} client:load />
</section>
