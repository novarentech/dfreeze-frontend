---
import { MapPin, Clock, Mail, Phone } from "lucide-react";
import LeafletMap from "@/components/LeafletMap";
import "leaflet/dist/leaflet.css";
---

<section id="lokasi" class="py-20 bg-slate-50/50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-left md:text-center mb-16">
      <span class="text-primary text-sm font-bold uppercase tracking-widest">LOKASI</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-slate-800">
        Temukan Lokasi Kami, Klinik Hewan D'FREEZE & SON
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Map Column -->
      <div class="relative group">
        <div 
          class="h-[350px] md:h-[450px] w-full rounded-3xl shadow-xl border border-slate-200 z-0 bg-slate-100 overflow-hidden"
        >
          <LeafletMap client:only="react" />
        </div>
        <!-- Decorative shadow behind map -->
        <div class="absolute -inset-4 bg-primary/5 rounded-[2.5rem] -z-10 blur-2xl group-hover:bg-primary/10 transition-colors"></div>
      </div>

      <!-- Details Column -->
      <div class="space-y-10">
        <!-- Alamat -->
        <div class="flex gap-1">
          <div class="shrink-0 w-12 h-12 flex items-start justify-start text-primary">
            <MapPin size={24} />
          </div>
          <div class="space-y-2">
            <h3 class="text-sm font-bold uppercase tracking-widest leading-none">ALAMAT</h3>
            <p class="text-slate-600 leading-relaxed text-sm md:text-base">
              Jl. Raya Stadion Maguwoharjo, Ngemplak (samping Indomaret Jodipati, Wedomartani, Kec. Ngemplak, Kabupaten Sleman, Daerah Istimewa Yogyakarta 55584
            </p>
          </div>
        </div>

        <!-- Jam Buka -->
        <div class="flex gap-1">
          <div class="shrink-0 w-12 h-12 flex items-start justify-start text-primary">
            <Clock size={24} />
          </div>
          <div class="space-y-2">
            <h3 class="text-sm font-bold uppercase tracking-widest leading-none">JAM BUKA</h3>
            <ul class="text-slate-600 text-sm md:text-base space-y-1">
              <li class="flex justify-between max-w-xs">
                <span>Senin &ndash; Jumat</span>
                <span class="font-medium">: 16.00 &ndash; 20.00 WIB</span>
              </li>
              <li class="flex justify-between max-w-xs">
                <span>Sabtu</span>
                <span class="font-medium">: 10.00 &ndash; 17.00 WIB</span>
              </li>
              <li class="flex justify-between max-w-xs">
                <span>Minggu</span>
                <span class="font-medium">: Tutup / Emergency Only</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Email -->
        <div class="flex gap-1">
          <div class="shrink-0 w-12 h-12 flex items-start justify-start text-primary">
            <Mail size={24} />
          </div>
          <div class="space-y-2">
            <h3 class="text-sm font-bold uppercase tracking-widest leading-none">EMAIL</h3>
            <a href="mailto:inaorthovetf@gmail.com" class="text-slate-600 hover:text-primary transition-colors text-sm md:text-base">
              inaorthovetf@gmail.com
            </a>
          </div>
        </div>

        <!-- Telepon -->
        <div class="flex gap-1">
          <div class="shrink-0 w-12 h-12 flex items-start justify-start text-primary">
            <Phone size={24} />
          </div>
          <div class="space-y-2">
            <h3 class="text-sm font-bold uppercase tracking-widest leading-none">TELEPON</h3>
            <a href="https://wa.me/628112609091" class="text-slate-600 hover:text-primary transition-colors text-sm md:text-base">
              0811-2609-091
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Subtle styling for Leaflet elements */
  .leaflet-container {
    font-family: inherit;
  }
  .leaflet-container a {
    color: #64748b !important;
  }
</style>
