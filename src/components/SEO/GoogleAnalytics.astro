---
// Mengambil ID GA dari Env Variable (jika ada)
const MEASUREMENT_ID = import.meta.env.PUBLIC_GA_ID;
const isProd = import.meta.env.PROD;
---

{isProd && MEASUREMENT_ID && (
  <!-- Global site tag (gtag.js) - Google Analytics -->
  <script is:inline type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${MEASUREMENT_ID}`}></script>
  <script is:inline type="text/partytown" define:vars={{ MEASUREMENT_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', MEASUREMENT_ID);
  </script>
)}
