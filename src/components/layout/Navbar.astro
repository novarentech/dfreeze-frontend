---
import logo from '@/assets/logo.png';
import MobileMenuToggle from '../ui/MobileMenuToggle';
import TopBar from './TopBar.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/',            label: 'Beranda',     active: pathname === '/' },
  { href: '/#about',      label: 'Tentang Kami', active: false },
  { href: '/#services',   label: 'Layanan',     active: false },
  { href: '/artikel',     label: 'Artikel',     active: pathname.startsWith('/artikel') },
  { href: '/faq',         label: 'Q&A',         active: pathname.startsWith('/faq') },
];

---

<header class="fixed top-0 z-40 w-full shadow-sm mx-auto bg-white">
  <TopBar />

  <!-- Main Navbar -->
  <div class="bg-background border-b border-slate-100">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between py-1">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group shrink-0" id="nav-logo">
          <div class="w-11 h-11 rounded-full flex items-center justify-center bg-background shadow group-hover:shadow-md transition-shadow overflow-hidden p-0">
            <img src={logo.src} alt="Logo" class="w-full h-full object-cover" />
          </div>
          <div class="flex flex-col justify-center">
            <span class="block text-[9px] sm:text-[11px] text-slate-500 font-medium tracking-wide uppercase leading-none">Klinik Hewan</span>
            <span class="block text-[13px] sm:text-[15px] font-extrabold text-slate-800 leading-tight tracking-wide">D'FREEZE &amp; SON</span>
          </div>
        </a>

        <!-- Desktop Nav Menu -->
        <nav class="hidden md:flex items-center gap-1 py-4" id="nav-menu">
          {navLinks.map((link) => (
            <a
              href={link.href}
              data-nav-link={link.href}
              class={`nav-link relative px-3 py-1 text-sm font-medium transition-all ${
                link.active
                  ? 'text-primary font-semibold is-active'
                  : 'text-slate-600 hover:text-primary transition-colors'
              }`}
            >
              {link.label}
              <span class={`underline-glow absolute bottom-0 left-0 w-full h-[2px] bg-primary origin-center transition-transform duration-300 ease-out ${link.active ? 'scale-x-100' : 'scale-x-0'}`}></span>


            </a>
          ))}
        </nav>


        <!-- CTA + Mobile Toggle -->
        <div class="flex items-center gap-2">
          <!-- Hubungi Kami Button -->
          <a
            href="https://wa.me/628112609091"
            id="nav-cta"
            class="hidden md:inline-flex items-center px-5 py-2 rounded-full bg-[#F5BC2B] hover:bg-[#e6ad20] text-sm font-semibold transition-all shadow-sm hover:shadow-md"
          >
            Hubungi Kami
          </a>

          <MobileMenuToggle client:load />
        </div>
      </div>

      <!-- Mobile Menu Dropdown -->
      <div id="mobile-menu" class="md:hidden grid grid-rows-[0fr] transition-all duration-300 ease-in-out opacity-0 -translate-y-2 pointer-events-none">
        <div class="overflow-hidden">
          <div class="pb-4 border-t border-slate-100 pt-2 space-y-1">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    data-nav-link={link.href}
                    class={`mobile-nav-link block px-3 py-2.5 text-sm font-medium rounded-lg mb-0.5 transition-colors ${
                    link.active
                        ? 'bg-teal-50 border-primary text-primary font-semibold'
                        : 'text-slate-600 hover:text-primary hover:bg-teal-50'
                    }`}
                >
                    {link.label}
                </a>
            ))}
            <a
            href="/kontak"
            class="mt-3 block text-center px-5 py-2.5 rounded-full bg-[#F5BC2B] hover:bg-[#e6ad20] text-sm font-semibold transition-colors"
            >
            Hubungi Kami
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function setupActiveNav() {
    const navLinks = document.querySelectorAll('[data-nav-link]');
    const sections = document.querySelectorAll('#hero, #about, #services, #fasilitas, #testimoni, #galeri, #cta, #lokasi');
    const isHomePage = window.location.pathname === '/';

    if (!isHomePage) return;

    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      let activeSectionId = null;

      // Find the currently intersecting section
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          activeSectionId = entry.target.getAttribute('id');
        }
      });

      if (activeSectionId === 'about') {
        updateActiveLink('/#about');
      } else if (activeSectionId === 'services') {
        updateActiveLink('/#services');
      } else if (activeSectionId) {
        updateActiveLink('/');
      }
    }, observerOptions);


    sections.forEach((section) => observer.observe(section));

    // Handle scroll to top specifically for Beranda
    let scrollTimeout: any;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const anySectionActive = Array.from(sections).some(section => {
          const rect = section.getBoundingClientRect();
          return rect.top < window.innerHeight / 2 && rect.bottom > window.innerHeight / 2;
        });

        if (!anySectionActive && window.location.pathname === '/') {
          updateActiveLink('/');
        }
      }, 100);
    });


    function updateActiveLink(href: string) {
      navLinks.forEach((link) => {
        const linkHref = link.getAttribute('href');
        const isActive = linkHref === href;
        
        // Desktop Classes
        if (link.classList.contains('nav-link')) {
          const glow = link.querySelector('.underline-glow');
          if (isActive) {
            link.classList.add('text-primary', 'font-semibold', 'is-active');
            link.classList.remove('text-slate-600');
            if (glow) glow.classList.replace('scale-x-0', 'scale-x-100');
          } else {
            link.classList.remove('text-primary', 'font-semibold', 'is-active');
            link.classList.add('text-slate-600');
            if (glow) glow.classList.replace('scale-x-100', 'scale-x-0');
          }
        }



        // Mobile Classes
        if (link.classList.contains('mobile-nav-link')) {
          if (isActive) {
            link.classList.add('bg-teal-50', 'text-primary', 'font-semibold');
            link.classList.remove('text-slate-600');
          } else {
            link.classList.remove('bg-teal-50', 'text-primary', 'font-semibold');
            link.classList.add('text-slate-600');
          }
        }
      });
    }
  }

  // Initial setup
  setupActiveNav();

  // Re-run on View Transitions (if enabled)
  document.addEventListener('astro:after-swap', setupActiveNav);
</script>

<style>
  /* Desktop Hover Effect */
  .nav-link:hover .underline-glow {
    transform: scaleX(1) !important;
  }
  
  .nav-link.is-active .underline-glow {
    transform: scaleX(1) !important;
  }

  .underline-glow {
    transform-origin: center !important;
  }
</style>


