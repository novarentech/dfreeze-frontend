# Variabel lingkungan untuk DFreeze Vet Clinic

# Base URL API backend eksternal / Strapi (tanpa trailing slash, sudah termasuk /api)
API_BACKEND_URL=https://dfreeze-api.novarentech.web.id/api

# Bearer token untuk otorisasi semua request ke Strapi (GET artikel & POST booking)
API_SECRET_KEY=your_secret_key_here
